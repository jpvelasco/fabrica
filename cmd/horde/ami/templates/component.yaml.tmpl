name: {{ .Name }}-{{ .Install }}
description: Installs Horde {{ .Version }} prerequisites ({{ .Install }} method) for fabrica horde create.
schemaVersion: 1.0

phases:
  - name: build
    steps:
{{- if eq .Install "docker" }}
      - name: InstallDocker
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - curl -fsSL https://get.docker.com | sh
            - systemctl enable docker
            - usermod -aG docker ubuntu
      - name: InstallComposeStack
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - mkdir -p /opt/horde /etc/horde
            - |
              cat >/opt/horde/docker-compose.yml <<'YAML'
              # Replace this file with the official Horde docker-compose.yml
              # from Engine/Source/Programs/Horde/HordeServer/docker-compose.yml
              # before baking the AMI. This stub is a placeholder so the
              # systemd unit has something to start.
              version: "3.8"
              services:
                placeholder:
                  image: hello-world
              YAML
      - name: InstallSystemdUnits
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - |
              cat >/etc/systemd/system/horde.service <<'UNIT'
              [Unit]
              Description=Horde Server (docker compose)
              After=network-online.target docker.service
              Requires=docker.service

              [Service]
              Type=oneshot
              RemainAfterExit=yes
              WorkingDirectory=/opt/horde
              ExecStart=/usr/bin/docker compose up -d
              ExecStop=/usr/bin/docker compose down
              ExecReload=/bin/sh -c '/usr/bin/docker compose pull && /usr/bin/docker compose up -d'

              [Install]
              WantedBy=multi-user.target
              UNIT
            - systemctl daemon-reload
            - systemctl enable horde
{{- else }}
      - name: InstallDotNet
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - wget -q https://packages.microsoft.com/config/ubuntu/22.04/packages-microsoft-prod.deb -O /tmp/ms.deb
            - dpkg -i /tmp/ms.deb
            - apt-get update -q
            - apt-get install -y dotnet-sdk-8.0
      - name: InstallMongoDB
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - curl -fsSL https://www.mongodb.org/static/pgp/server-7.0.asc | gpg -o /usr/share/keyrings/mongodb-7.0.gpg --dearmor
            - echo 'deb [arch=amd64,arm64 signed-by=/usr/share/keyrings/mongodb-7.0.gpg] https://repo.mongodb.org/apt/ubuntu jammy/mongodb-org/7.0 multiverse' >/etc/apt/sources.list.d/mongodb-org-7.0.list
            - apt-get update -q
            - apt-get install -y mongodb-org
            - systemctl enable mongod
      - name: InstallRedis
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - apt-get install -y redis-server
            - systemctl enable redis-server
      - name: InstallHordeBinary
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - mkdir -p /opt/horde /etc/horde
            - aws s3 sync s3://REPLACE_WITH_YOUR_BUCKET/horde-bin/ /opt/horde/ --exact-timestamps
            - chmod +x /opt/horde/HordeServer
            - |
              cat >/etc/horde/env <<'ENV'
              ASPNETCORE_ENVIRONMENT=Production
              Horde__DataDir=/etc/horde
              ENV
            - |
              cat >/etc/systemd/system/horde.service <<'UNIT'
              [Unit]
              Description=Horde Server
              After=mongod.service redis-server.service
              Requires=mongod.service

              [Service]
              ExecStart=/usr/bin/dotnet /opt/horde/HordeServer.dll
              WorkingDirectory=/opt/horde
              EnvironmentFile=/etc/horde/env
              Restart=on-failure
              RestartSec=5

              [Install]
              WantedBy=multi-user.target
              UNIT
            - systemctl daemon-reload
            - systemctl enable horde
{{- end }}

  - name: validate
    steps:
      - name: VerifyUnitsEnabled
        action: ExecuteBash
        inputs:
          commands:
            - set -euo pipefail
            - systemctl is-enabled horde
{{- if eq .Install "docker" }}
            - systemctl is-enabled docker
{{- else }}
            - systemctl is-enabled mongod
            - systemctl is-enabled redis-server
{{- end }}
            - test -d /etc/horde

  - name: test
    steps:
      - name: HordeUnitDiscoverable
        action: ExecuteBash
        inputs:
          commands:
            - systemctl cat horde >/dev/null
